{
  "kind": "singleType",
  "collectionName": "abouts",
  "info": {
    "singularName": "about",
    "pluralName": "abouts",
    "displayName": "About"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "portrait": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "portrait_caption": {
      "type": "string"
    },
    "bio": {
      "type": "richtext"
    },
    "favourite_movies": {
      "type": "component",
      "component": "shared.favourite-movies",
      "repeatable": true
    },
    "favourite_podcasts": {
      "type": "component",
      "component": "shared.favourite-podcasts",
      "repeatable": true
    },
    "page_title": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "director": {
      "type": "string"
    },
    "run_time": {
      "type": "string"
    },
    "excerpt": {
      "type": "text"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 10
    },
    "rating_metric": {
      "type": "string"
    },
    "would_recommend": {
      "type": "boolean"
    },
    "would_rewatch": {
      "type": "boolean"
    },
    "genres": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::genre.genre"
    },
    "byline": {
      "type": "string"
    }
  }
}
